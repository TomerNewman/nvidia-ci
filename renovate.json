{
  "enabledManagers": ["regex"],
  "regexManagers": [
    {
      "fileMatch": ["^versions\\.yaml$"],
      "matchStrings": [
        "(?<prefix>gpu_operator_staging_digest:\\s*\")(?<currentValue>sha256:[0-9a-f]+)(?<suffix>\")"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "registry.gitlab.com/nvidia/kubernetes/gpu-operator/staging/gpu-operator-bundle",
      "versioningTemplate": "regex",
      "extractVersionTemplate": "^(?<version>sha256:[0-9a-f]+)$"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "registry.gitlab.com/nvidia/kubernetes/gpu-operator/staging/gpu-operator-bundle"
      ],
      "prBody": "/test 4.12-nvidia-gpu-operator-e2e-latest 4.14-nvidia-gpu-operator-e2e-latest 4.15-nvidia-gpu-operator-e2e-latest 4.16-nvidia-gpu-operator-e2e-latest 4.17-nvidia-gpu-operator-e2e-latest"
    }
  ]
}
